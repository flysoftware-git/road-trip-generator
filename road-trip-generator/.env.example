# Road Trip Itinerary Generator — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Azure OpenAI (required)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Brave Search API (required — replaces retired Bing v7 and deprecated Google PSE)
# Sign up free (2 min, no credit card) at: https://api.search.brave.com
# Free tier: 2,000 queries/month — enough for many full generation runs
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# NPS API (optional — DEMO_KEY used if omitted, but rate-limited)
# Free key (email arrives in minutes): https://www.nps.gov/subjects/developer/get-started.htm
NPS_API_KEY=your-nps-api-key-here
