# Road Trip Itinerary Generator — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# LLM provider keys (choose based on config.yaml ai.provider or trip.llm.provider)

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_API_VERSION=2023-06-01
# ANTHROPIC_API_BASE=https://api.anthropic.com/v1/messages

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_API_BASE=https://generativelanguage.googleapis.com

# Azure OpenAI (legacy compatibility only)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Brave Search API (required — replaces retired Bing v7 and deprecated Google PSE)
# Sign up free (2 min, no credit card) at: https://api.search.brave.com
# Free tier: 2,000 queries/month — enough for many full generation runs
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# NPS API (optional — DEMO_KEY used if omitted, but rate-limited)
# Free key (email arrives in minutes): https://www.nps.gov/subjects/developer/get-started.htm
NPS_API_KEY=your-nps-api-key-here
